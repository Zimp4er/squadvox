# ────────────────────────────────────────
# Скопируйте этот файл в .env и заполните
# Для хэша пароля запустите:
#   node scripts/hash-password.js ВАШ_ПАРОЛЬ
# ────────────────────────────────────────

# Сервер
PORT=3000
TURN_HOST=squadvox.ru

# Пользователи (до 4-х)
USER_1_LOGIN=alice
USER_1_PASSWORD_HASH=ЗАМЕНИТЕ_НА_SHA256_ХЭШ

USER_2_LOGIN=bob
USER_2_PASSWORD_HASH=ЗАМЕНИТЕ_НА_SHA256_ХЭШ

# USER_3_LOGIN=charlie
# USER_3_PASSWORD_HASH=ЗАМЕНИТЕ_НА_SHA256_ХЭШ

# USER_4_LOGIN=dave
# USER_4_PASSWORD_HASH=ЗАМЕНИТЕ_НА_SHA256_ХЭШ

# Котерн (тот же секрет что в /etc/turnserver.conf → static-auth-secret)
COTURN_SECRET=ЗАМЕНИТЕ_НА_ВАШ_СЕКРЕТ_КОТЕРНА
